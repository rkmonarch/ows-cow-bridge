# ── LLM (pick one) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

LLM_MODEL=gpt-4o

# ── OWS vault ─────────────────────────────────────────────────────────────────
# Directory where encrypted wallet keystores are stored.
# Defaults to ~/.ows/wallets/ if not set (recommended).
# OWS_VAULT_DIR=/custom/path/to/vaults

# Password used to encrypt/decrypt wallet keystores.
# If not set, the CLI will prompt interactively.
# For automated/agent use you may set it here — keep this file private.
OWS_VAULT_PASSWORD=your_secure_passphrase

# ── RPC endpoints (public fallbacks in config.py) ─────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com
BASE_RPC_URL=https://mainnet.base.org
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
OP_RPC_URL=https://mainnet.optimism.io
POLYGON_RPC_URL=https://polygon-rpc.com
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# ── Optional ──────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=
MOONPAY_PUBLISHABLE_KEY=pk_live_...
